# .gitignore for Unity projects
# Recommended additions for Unity + macOS + VisualStudio

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
MemoryCaptures/

# Asset meta data should be tracked, but the following are safe to ignore:
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage

# User-specific files
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb

# Visual Studio / MonoDevelop
.vs/
# Visual Studio Code workspace settings
.vscode/

# Rider
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Crashlytics / Fabric
crashlytics-build.properties

# Gradle
.gradle/

# Node
node_modules/

# Unity cache server
cache/

# Auto-generated by Unity
sysinfo.txt

# Plugins
*.dll
*.mdb

# Shader compiled files
*.shader.meta

# Ignore the following files that are regenerated or user-specific
Assets/Plugins/Editor/**/Generated/

# Project settings that should be kept in source control
# (keep ProjectSettings/manifest.json and Packages/manifest.json tracked)
